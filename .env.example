# 作用：
# 本文件提供波兰签证预约检查工具的环境变量模板。
#
# 为什么这样写：
# 通过模板集中声明可配置项，避免把敏感信息直接写入代码。
#
# 输入：
# 无
#
# 输出：
# 无
#
# 注意：
# - 复制为 .env 后再填写真实值。
# - 不要把 .env 提交到版本控制。

CHECK_INTERVAL_MINUTES=15
HEADLESS=false
CAPTCHA_MODE=prompt
ARTIFACTS_DIR=artifacts
NOTIFY_MACOS=true
NOTIFY_WEBHOOK_URL=
WEBHOOK_AUTH_HEADER=
WEBHOOK_AUTH_TOKEN=
